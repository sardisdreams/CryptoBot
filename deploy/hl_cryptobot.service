[Unit]
Description=CryptoBot Hyperliquid Perpetuals Bot
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=cryptobot
WorkingDirectory=/opt/cryptobot/app
ExecStart=/opt/cryptobot/app/.venv/bin/python hl_main.py
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
