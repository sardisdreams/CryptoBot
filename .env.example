# Base chain RPC
BASE_RPC_URL=https://mainnet.base.org

# Your wallet private key (NEVER commit this)
PRIVATE_KEY=0x...

# Optional: Alchemy or Infura RPC for better rate limits
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Trading config
MAX_TRADE_SIZE_ETH=0.01
SLIPPAGE_TOLERANCE=0.005

# Dashboard auth (set these when deploying to cloud — leave blank for local)
DASHBOARD_USER=
DASHBOARD_PASS=

# Logging
LOG_LEVEL=INFO
